---
import Layout from "../../layouts/Layout.astro";
import { SITE_TITLE } from "../../consts";
import { getCollection } from "astro:content";

const posts = (
    await getCollection("blog", ({ data }) => {
        return data.draft !== true;
    })
).sort((a, b) => {
    const dateDiff = b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
    if (dateDiff !== 0) return dateDiff;
    return (a.data.weight ?? 0) - (b.data.weight ?? 0);
});

// Group posts by year
const postsByYear = posts.reduce(
    (acc, post) => {
        const year = post.data.pubDate.getFullYear();
        if (!acc[year]) acc[year] = [];
        acc[year].push(post);
        return acc;
    },
    {} as Record<number, typeof posts>,
);

const years = Object.keys(postsByYear)
    .sort((a, b) => Number(b) - Number(a))
    .map(Number);
---

<Layout title={SITE_TITLE}>
    <div class="max-w-[800px] mx-auto">
        <!-- Intro Section -->
        <section class="mb-16">
            <p class="text-lg text-zinc-700 leading-relaxed">
                I'm <strong>Sarthak Makhija</strong>, a <strong
                    >Principal Architect</strong
                > at <strong>Caizin</strong>. I write long-form essays on
                storage engines, databases, refactoring, and engineering
                trade-offs, for engineers who want to understand how things
                actually work.
            </p>
            <p class="intent">Writing for future-me.</p>
            <div class="flex flex-wrap gap-4 mt-6">
                <a
                    href="/top-essays"
                    class="font-mono text-sm text-white bg-zinc-900 px-4 py-2 rounded-md hover:bg-zinc-700 transition-all"
                >
                    Top Essays →
                </a>
                <a
                    href="/trainings"
                    class="font-mono text-sm text-zinc-900 border border-zinc-900 px-4 py-2 rounded-md hover:bg-zinc-100 transition-all"
                >
                    Trainings →
                </a>
                <a
                    href="/talks"
                    class="font-mono text-sm text-zinc-900 border border-zinc-900 px-4 py-2 rounded-md hover:bg-zinc-100 transition-all"
                >
                    Talks →
                </a>
            </div>
        </section>

        <!-- Start Here Section -->
        <section class="mb-16">
            <h2
                class="font-mono text-sm uppercase tracking-wider text-zinc-900 mb-6 font-bold"
            >
                Start Here
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div class="border border-zinc-100 rounded-lg p-5 hover:border-zinc-300 hover:shadow-sm hover:-translate-y-0.5 transition-all duration-300 group/card">
                    <h3 class="font-mono font-bold text-sm text-zinc-900 mb-3">
                        Storage Engines
                    </h3>
                    <ul class="flex flex-col gap-2">
                        <li>
                            <a
                                href="/en/blog/bitcask/"
                                class="font-mono font-medium text-base text-zinc-700 hover:text-black hover:translate-x-1 inline-block transition-all"
                            >
                                Bitcask: A Log-Structured Hash Table
                            </a>
                        </li>
                        <li>
                            <a
                                href="/en/blog/wisckey_ssd_conscious_key_value_store/"
                                class="font-mono font-medium text-base text-zinc-700 hover:text-black hover:translate-x-1 inline-block transition-all"
                            >
                                WiscKey: SSD-Conscious Key-Value Store
                            </a>
                        </li>
                        <li>
                            <a
                                href="/en/blog/bloom_filter/"
                                class="font-mono font-medium text-base text-zinc-700 hover:text-black hover:translate-x-1 inline-block transition-all"
                            >
                                Bloom Filters
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="border border-zinc-100 rounded-lg p-5 hover:border-zinc-300 hover:shadow-sm hover:-translate-y-0.5 transition-all duration-300 group/card">
                    <h3 class="font-mono font-bold text-sm text-zinc-900 mb-3">
                        Query Engines
                    </h3>
                    <ul class="flex flex-col gap-2">
                        <li>
                            <a
                                href="/en/blog/inside_a_query_engine_introduction/"
                                class="font-mono font-medium text-base text-zinc-700 hover:text-black hover:translate-x-1 inline-block transition-all"
                            >
                                Introduction
                            </a>
                        </li>
                        <li>
                            <a
                                href="/en/blog/inside_a_query_engine_lexical_analysis/"
                                class="font-mono font-medium text-base text-zinc-700 hover:text-black hover:translate-x-1 inline-block transition-all"
                            >
                                Lexical Analysis
                            </a>
                        </li>
                        <li>
                            <a
                                href="/en/blog/inside_a_query_engine_logical_plan/"
                                class="font-mono font-medium text-base text-zinc-700 hover:text-black hover:translate-x-1 inline-block transition-all"
                            >
                                Logical Plans
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="border border-zinc-100 rounded-lg p-5 hover:border-zinc-300 hover:shadow-sm hover:-translate-y-0.5 transition-all duration-300 group/card">
                    <h3 class="font-mono font-bold text-sm text-zinc-900 mb-3">
                        Refactoring
                    </h3>
                    <ul class="flex flex-col gap-2">
                        <li>
                            <a
                                href="/en/blog/refactoring_mindset/"
                                class="font-mono font-medium text-base text-zinc-700 hover:text-black hover:translate-x-1 inline-block transition-all"
                            >
                                Refactoring Mindset
                            </a>
                        </li>
                        <li>
                            <a
                                href="/en/blog/refactoring_in_the_age_of_ai/"
                                class="font-mono font-medium text-base text-zinc-700 hover:text-black hover:translate-x-1 inline-block transition-all"
                            >
                                Refactoring in the Age of AI
                            </a>
                        </li>
                        <li>
                            <a
                                href="/en/blog/lets_define_legacy_code/"
                                class="font-mono font-medium text-base text-zinc-700 hover:text-black hover:translate-x-1 inline-block transition-all"
                            >
                                Defining Legacy Code
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Essay List -->
        <section>
            <h2
                class="font-mono text-sm uppercase tracking-wider text-zinc-900 mb-8 font-bold"
            >
                Essays
            </h2>

            <div class="flex flex-col">
                {
                    years.map((year) => (
                        <div class="mb-8">
                            {postsByYear[year].map((post, index) => (
                                <div class="group flex items-baseline py-2 border-b border-zinc-100 hover:border-zinc-200 transition-colors">
                                    {/* Year column: Show only for first item of the year */}
                                    <div class="w-16 font-mono text-sm text-zinc-900 shrink-0 font-bold">
                                        {index === 0 ? year : ""}
                                    </div>

                                    {/* Date Column */}
                                    <div class="w-16 font-mono text-sm text-zinc-900 shrink-0 hidden sm:block font-bold">
                                        {post.data.pubDate.toLocaleDateString(
                                            "en-GB",
                                            {
                                                day: "2-digit",
                                                month: "2-digit",
                                            },
                                        )}
                                    </div>

                                    {/* Title Column */}
                                    <a
                                        href={`/en/blog/${post.slug}/`}
                                        class="font-mono font-medium text-base text-zinc-700 hover:text-black hover:translate-x-1 transition-all"
                                    >
                                        {post.data.title}
                                    </a>
                                </div>
                            ))}
                        </div>
                    ))
                }
            </div>
        </section>
    </div>
</Layout>
