---
import Layout from "../../layouts/Layout.astro";

const title = "Gamifying Refactoring";
const description = "Turn the art of refactoring into a measurable science. This training turns code cleanup into a challenge: can you justify a code smell without using vague terms like 'readability' or 'maintainability'?";
---

<Layout title={title} description={description}>
    <div class="max-w-[800px] mx-auto font-sans">
        
        <!-- Breadcrumb & Back Link -->
        <div class="mb-8">
            <a href="/trainings" class="text-sm font-mono text-zinc-500 hover:text-zinc-900 transition-colors inline-flex items-center gap-1">
                ← Back to Trainings
            </a>
        </div>

        <!-- Hero Header -->
        <section class="mb-12">
            <div class="flex items-center gap-4 mb-6">
                <div class="p-3 bg-purple-50/50 rounded-xl border border-purple-100 shrink-0">
                    <!-- Gamepad icon -->
                    <svg class="w-8 h-8 text-purple-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="6" y1="12" x2="10" y2="12" />
                        <line x1="8" y1="10" x2="8" y2="14" />
                        <line x1="15" y1="13" x2="15.01" y2="13" />
                        <line x1="18" y1="11" x2="18.01" y2="11" />
                        <rect x="2" y="6" width="20" height="12" rx="3" />
                    </svg>
                </div>
                <div>
                    <h1 class="text-3xl font-sans font-bold text-zinc-900 leading-tight mb-2">
                        {title}
                    </h1>
                    <div class="flex flex-wrap gap-2 text-xs md:text-sm">
                        <span class="px-3 py-1 bg-blue-50 border border-blue-100 rounded-full text-blue-800 font-medium">
                            Format: Instructor-led training
                        </span>
                        <span class="px-3 py-1 bg-blue-50 border border-blue-100 rounded-full text-blue-800 font-medium">
                            Duration: 5 hours
                        </span>
                        <span class="px-3 py-1 bg-blue-50 border border-blue-100 rounded-full text-blue-800 font-medium">
                            Availability: On request
                        </span>
                    </div>
                </div>
            </div>
            
            <p class="text-lg text-zinc-700 leading-relaxed mb-8">
                {description}
            </p>
            <div class="mb-8">
                <a href="https://gamifying-refactoring.github.io/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 border border-zinc-300 hover:border-zinc-950 hover:bg-zinc-50 text-zinc-800 font-sans font-semibold text-sm rounded-xl transition-all shadow-sm">
                    View Game Site & Materials <span class="group-hover:translate-x-1 transition-transform">→</span>
                </a>
            </div>
        </section>

        <!-- Rules & Curriculum -->
        <section class="mb-12">
            <div class="bg-blue-50/30 border border-blue-100 rounded-2xl p-6 md:p-8 mb-8">
                <h3 class="font-sans font-bold text-blue-900 mb-3 text-lg">The Game Rules</h3>
                <ul class="space-y-3.5 text-zinc-700 text-sm md:text-base">
                    <li class="flex items-start gap-3">
                        <span class="text-blue-600 font-bold">1.</span>
                        <span><strong>Identify</strong> smells using concrete evidence, not gut feelings.</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <span class="text-blue-600 font-bold">2.</span>
                        <span><strong>Justify</strong> your refactoring without using "ilities" (readability, flexibility).</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <span class="text-blue-600 font-bold">3.</span>
                        <span><strong>Go Beyond</strong> abstract reasoning to find measurable problems.</span>
                    </li>
                </ul>
                <p class="mt-6 text-sm text-blue-800 italic border-l-2 border-blue-300 pl-4 font-sans">
                    "Don't state 'Long method is a smell because it is not readable'. Consider this an opportunity to find reasoning that is measurable."
                </p>
            </div>
        </section>

        <!-- Key Outcomes -->
        <section class="mb-16">
            <div class="bg-zinc-50 border border-zinc-200/80 rounded-2xl p-6 md:p-8">
                <h3 class="font-sans font-bold text-zinc-900 mb-4 text-lg">After this training, you will be able to</h3>
                <ul class="space-y-3.5 text-zinc-700">
                    <li class="flex items-start gap-3 text-sm md:text-base">
                        <span class="text-purple-600 font-bold">1.</span>
                        <span>Recognize code smells with precision, using evidence rather than intuition</span>
                    </li>
                    <li class="flex items-start gap-3 text-sm md:text-base">
                        <span class="text-purple-600 font-bold">2.</span>
                        <span>Justify refactoring decisions without leaning on vague terms like "readability" or "maintainability"</span>
                    </li>
                    <li class="flex items-start gap-3 text-sm md:text-base">
                        <span class="text-purple-600 font-bold">3.</span>
                        <span>Make small, safe, incremental changes that improve code without breaking behavior</span>
                    </li>
                </ul>
            </div>
        </section>

        <!-- Request Section -->
        <section class="mb-12 border border-zinc-200 rounded-2xl p-6 md:p-8 text-center bg-zinc-50/50">
            <h3 class="text-xl font-sans font-bold text-zinc-950 mb-3 font-sans">Interested in running this training for your team?</h3>
            <p class="text-sm text-zinc-600 max-w-[600px] mx-auto mb-6">
                This workshop is interactive and designed to be run live with engineering teams to set a shared baseline for code quality and refactoring practices.
            </p>
            <div class="flex flex-wrap justify-center gap-4">
                <a href="mailto:sarthak.makhija@tech-lessons.in" class="px-5 py-2.5 bg-zinc-900 hover:bg-zinc-800 text-white font-mono text-sm rounded-md transition-all">
                    Email for details
                </a>
                <a href="https://www.linkedin.com/in/sarthak-makhija/" target="_blank" rel="noopener noreferrer" class="px-5 py-2.5 border border-zinc-900 hover:bg-zinc-100 text-zinc-900 font-mono text-sm rounded-md transition-all">
                    Connect on LinkedIn
                </a>
            </div>
        </section>

    </div>
</Layout>
