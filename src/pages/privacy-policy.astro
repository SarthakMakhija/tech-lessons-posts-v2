---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Privacy Policy - tech-lessons.in">
    <div class="max-w-[800px] mx-auto font-sans">
        <section class="mb-12">
            <h1 class="font-sans font-bold text-3xl mb-4 text-zinc-900">Privacy Policy</h1>
            <p class="text-zinc-500 text-sm font-sans mt-1">
                Last updated: July 2026
            </p>
        </section>

        <section class="space-y-8">
            <p class="text-zinc-600 text-base leading-relaxed font-sans">
                We value your privacy and are committed to protecting your personal data.
            </p>

            <div class="space-y-6">
                <div>
                    <h3 class="font-sans font-bold text-lg text-zinc-900 mb-2">Data Collection</h3>
                    <p class="text-zinc-600 text-base leading-relaxed font-sans">
                        We collect minimal essential information required to deliver our educational services, including your name and email address.
                    </p>
                </div>

                <div>
                    <h3 class="font-sans font-bold text-lg text-zinc-900 mb-2">Data Usage</h3>
                    <p class="text-zinc-600 text-base leading-relaxed font-sans">
                        Your contact information is strictly used to send live session invitations, grant repository access, and communicate operational training updates.
                    </p>
                </div>

                <div>
                    <h3 class="font-sans font-bold text-lg text-zinc-900 mb-2">Data Protection</h3>
                    <p class="text-zinc-600 text-base leading-relaxed font-sans">
                        We do not track your browsing habits, sell your information, or share your data with any third-party marketing agencies. All financial transactions are processed securely through our payment gateway partner (Razorpay), and we never store your card or bank details on our servers.
                    </p>
                </div>
            </div>
        </section>
    </div>
</Layout>
