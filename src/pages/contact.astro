---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact Us - tech-lessons.in">
    <div class="max-w-[800px] mx-auto font-sans">
        <section class="mb-12">
            <h1 class="font-sans font-bold text-3xl mb-4 text-zinc-900">Contact Us</h1>
            <p class="text-zinc-500 text-sm font-sans mt-1">
                Get in touch for training inquiries, support requests, or feedback.
            </p>
        </section>

        <section class="space-y-6">
            <p class="text-zinc-600 text-base leading-relaxed font-sans">
                For any queries, support requests, or questions regarding our technical trainings or digital engineering materials, please reach out to us at:
            </p>
            <div class="bg-zinc-50 border border-zinc-200/60 rounded-2xl p-6 space-y-4">
                <div>
                    <h3 class="font-sans font-bold text-zinc-950 text-sm uppercase tracking-wider mb-1">Business Email</h3>
                    <a href="mailto:sarthak.makhija@tech-lessons.in" class="font-sans text-blue-600 hover:underline text-base font-medium">
                        sarthak.makhija@tech-lessons.in
                    </a>
                </div>
                <div class="border-t border-zinc-200/60 pt-4">
                    <h3 class="font-sans font-bold text-zinc-950 text-sm uppercase tracking-wider mb-1">Business Contact</h3>
                    <a href="tel:+919510196963" class="font-sans text-blue-600 hover:underline text-base font-medium">
                        +91 9510196963
                    </a>
                </div>
            </div>
        </section>
    </div>
</Layout>
