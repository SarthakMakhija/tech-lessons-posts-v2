---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Terms and Conditions - tech-lessons.in">
    <div class="max-w-[800px] mx-auto font-sans">
        <section class="mb-12">
            <h1 class="font-sans font-bold text-3xl mb-4 text-zinc-900">Terms and Conditions</h1>
            <p class="text-zinc-500 text-sm font-sans mt-1">
                Last updated: July 2026
            </p>
        </section>

        <section class="space-y-8">
            <p class="text-zinc-600 text-base leading-relaxed font-sans">
                Welcome to tech-lessons. By accessing our website (<a href="https://tech-lessons.in" class="text-blue-600 hover:underline font-sans">https://tech-lessons.in</a>), enrolling in our live technical trainings, or purchasing any digital materials, you agree to comply with and be bound by the following terms:
            </p>

            <div class="space-y-6">
                <div>
                    <h3 class="font-sans font-bold text-lg text-zinc-900 mb-2">Intellectual Property</h3>
                    <p class="text-zinc-600 text-base leading-relaxed font-sans">
                        All instructional video content, design architecture walkthroughs, and source code repositories provided during the training are for your personal, educational use only. Redistribution, republishing, or commercial exploitation of these materials without explicit written permission is strictly prohibited.
                    </p>
                </div>

                <div>
                    <h3 class="font-sans font-bold text-lg text-zinc-900 mb-2">Account Access</h3>
                    <p class="text-zinc-600 text-base leading-relaxed font-sans">
                        Access keys, community chat invitations, and GitHub repository access are non-transferable and mapped to a single individual user.
                    </p>
                </div>

                <div>
                    <h3 class="font-sans font-bold text-lg text-zinc-900 mb-2">Modifications</h3>
                    <p class="text-zinc-600 text-base leading-relaxed font-sans">
                        We reserve the right to alter training schedules or update curriculum materials to maintain technical accuracy with modern systems standards.
                    </p>
                </div>
            </div>
        </section>
    </div>
</Layout>
